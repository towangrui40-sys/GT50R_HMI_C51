  83          //读DGUS中的VP变量数据
  84          //addr:就是直接传入DGUS中的地址
  85          //buf:缓冲区
  86          //len:读取的字数,一个字等于2个字节
  87          void sys_read_vp(u16 addr,u8* buf,u16 len)
  88          {   
  89   1        u8 i; 
  90   1        
  91   1        i = (u8)(addr&0x01);
  92   1        addr >>= 1;
  93   1        ADR_H = 0x00;
  94   1        ADR_M = (u8)(addr>>8);
  95   1        ADR_L = (u8)addr;
  96   1        ADR_INC = 0x01;
  97   1        RAMMODE = 0xAF;
  98   1        while(APP_ACK==0);
  99   1        while(len>0)
 100   1        {   
 101   2          APP_EN=1;
 102   2          while(APP_EN==1);
 103   2          if((i==0)&&(len>0))   
 104   2          {   
 105   3            *buf++ = DATA3;
 106   3            *buf++ = DATA2;                      
 107   3            i = 1;
 108   3            len--;  
 109   3          }
 110   2          if((i==1)&&(len>0))   
 111   2          {   
 112   3            *buf++ = DATA1;
 113   3            *buf++ = DATA0;                      
 114   3            i = 0;
 115   3            len--;  
