 121          
 122          //写DGUS中的VP变量数据
 123          //addr:就是直接传入DGUS中的地址
 124          //buf:缓冲区
 125          //len:被发送数据的字数,一个字等于2个字节
 126          void sys_write_vp(u16 addr,u8* buf,u16 len)
 127          {   
 128   1        u8 i;  
 129   1        
 130   1        i = (u8)(addr&0x01);
 131   1        addr >>= 1;
 132   1        ADR_H = 0x00;
 133   1        ADR_M = (u8)(addr>>8);
 134   1        ADR_L = (u8)addr;    
 135   1        ADR_INC = 0x01;
 136   1        RAMMODE = 0x8F;
 137   1        while(APP_ACK==0);
 138   1        if(i && len>0)
 139   1        { 
 140   2          RAMMODE = 0x83; 
 141   2          DATA1 = *buf++;   
 142   2          DATA0 = *buf++; 
 143   2          APP_EN = 1;   
 144   2          len--;
 145   2        }
 146   1        RAMMODE = 0x8F;
 147   1        while(len>=2)
 148   1        { 
 149   2          DATA3 = *buf++;   
 150   2          DATA2 = *buf++;
 151   2          DATA1 = *buf++;   
 152   2          DATA0 = *buf++;
 153   2          APP_EN = 1;   
 154   2          len -= 2;
 155   2        }
 156   1        if(len)
 157   1        { 
 158   2          RAMMODE = 0x8C;
 159   2          DATA3 = *buf++;   
 160   2          DATA2 = *buf++;
 161   2          APP_EN = 1;
 162   2        }
 163   1        RAMMODE = 0x00;
 164   1      } 
