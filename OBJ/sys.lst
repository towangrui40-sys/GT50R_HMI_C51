 200          //绘制2D形状
 201          void sys_draw_shape(u16 * shape_data)
 202          {
 203   1        #define SHAPE_NUM   1       //只绘制一个
 204   1        #define END_FLAG    0xff00  //绘制结束标记
 205   1        u8 len;
 206   1        
 207   1        switch(shape_data[1])
 208   1        {
 209   2          case SHAPE_TYPE_POINT://绘制点
 210   2            ((SHAPE_DATA_POINT*)shape_data)->shape_num = SHAPE_NUM;
 211   2            ((SHAPE_DATA_POINT*)shape_data)->end_flag = END_FLAG;
 212   2            len = sizeof(SHAPE_DATA_POINT)-2;
 213   2            break;
 214   2          case SHAPE_TYPE_LINE://端点连线或线段
 215   2            ((SHAPE_DATA_LINE*)shape_data)->shape_num = SHAPE_NUM;
 216   2            ((SHAPE_DATA_LINE*)shape_data)->end_flag = END_FLAG;
 217   2            len = sizeof(SHAPE_DATA_LINE)-2;
 218   2            break;
 219   2          case SHAPE_TYPE_RECT://画矩形
 220   2          case SHAPE_TYPE_FILL_RECT://画填充矩形
 221   2            ((SHAPE_DATA_RECT*)shape_data)->shape_num = SHAPE_NUM;
 222   2            ((SHAPE_DATA_RECT*)shape_data)->end_flag = END_FLAG;
 223   2            len = sizeof(SHAPE_DATA_RECT)-2;
 224   2            break;
 225   2          case SHAPE_TYPE_AREA_COPY://界面区域拷贝
 226   2            ((SHAPE_DATA_AREA_COPY*)shape_data)->shape_num = SHAPE_NUM;
 227   2            ((SHAPE_DATA_AREA_COPY*)shape_data)->end_flag = END_FLAG;
 228   2            len = sizeof(SHAPE_DATA_AREA_COPY)-2;
 229   2            break;
 230   2          case SHAPE_TYPE_VER_LINE://频谱,垂直线
 231   2            ((SHAPE_DATA_VER_LINE*)shape_data)->shape_num = SHAPE_NUM;
 232   2            ((SHAPE_DATA_VER_LINE*)shape_data)->end_flag = END_FLAG;
 233   2            len = sizeof(SHAPE_DATA_VER_LINE)-2;
 234   2            break;    
 235   2        }
 236   1        
 237   1        sys_write_vp(shape_data[0],(u8*)(shape_data+1),len/2);
 238   1      }
