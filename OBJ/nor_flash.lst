   5          xdata u8 norflash_cmd[8];
   6          
   7          
   8          //向T5L内部自带的nor flash写入数据
   9          //addr:nor flash的地址,必须为偶数,范围为:0x000000-0x027FFE,然后一个地址对应2个字节,即总容量为320KB
  10          //buff:需要写入的缓冲区,长度至少大于len*2
  11          //len:写入的字数,必须为偶数,而且写入的最大长度也有限制,这个跟CACHE_ADDR的值有关系
  12          void norflash_write(u32 addr,u8* buff,u16 len)
  13          {
  14   1        //1.先把buff中的数据写入到DGUSII可用变量区(CACHE_ADDR)缓存一下
  15   1        sys_write_vp(CACHE_ADDR,buff,len);
  16   1        
  17   1        //2.然后再把CACHE_ADDR处的内容写入到nor flash中
  18   1        norflash_cmd[0] = NOR_FLASH_WRITE;//写操作
  19   1        norflash_cmd[1] = (addr>>16)&0xff;//nor flash地址
  20   1        norflash_cmd[2] = (addr>>8)&0xff;
  21   1        norflash_cmd[3] = addr&0xff;
  22   1        norflash_cmd[4] = (CACHE_ADDR>>8)&0xff;//dgusii数据地址
  23   1        norflash_cmd[5] = CACHE_ADDR&0xff;
  24   1        norflash_cmd[6] = (len>>8)&0xff;//写入的数据长度
  25   1        norflash_cmd[7] = len&0xff;
  26   1        sys_write_vp(NOR_FLASH_ADDR,norflash_cmd,4);
  27   1        
  28   1        //3.等待操作完成
  29   1        while(1)
  30   1        {
  31   2          sys_read_vp(NOR_FLASH_ADDR,norflash_cmd,2);//只需读取0x0008变量的前2个字,然后判断D7是否为0
  32   2          if(norflash_cmd[0]==0)
  33   2            break;
  34   2          sys_delay_about_ms(1);//这个延时必须加,可以防止莫名其妙的错误
  35   2        }
  36   1      }
