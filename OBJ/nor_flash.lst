  39          
  40          //向T5L内部自带的nor flash读取数据
  41          //addr:nor flash的地址,必须为偶数,范围为:0x000000-0x027FFE,然后一个地址对应2个字节,即总容量为320KB
  42          //buff:需要读入的缓冲区,长度至少大于len*2
  43          //len:读取的字数,必须为偶数,而且写入的最大长度也有限制,这个跟CACHE_ADDR的值有关系
  44          void norflash_read(u32 addr,u8* buff,u16 len)
  45          {
  46   1        //1.把nor flash中的内容读取到CACHE_ADDR
  47   1        norflash_cmd[0] = NOR_FLASH_READ;//读操作
  48   1        norflash_cmd[1] = (addr>>16)&0xff;//nor flash地址
  49   1        norflash_cmd[2] = (addr>>8)&0xff;
  50   1        norflash_cmd[3] = addr&0xff;
  51   1        norflash_cmd[4] = (CACHE_ADDR>>8)&0xff;//dgusii数据地址
  52   1        norflash_cmd[5] = CACHE_ADDR&0xff;
  53   1        norflash_cmd[6] = (len>>8)&0xff;//写入的数据长度
C51 COMPILER V9.60.7.0   NOR_FLASH                                                         06/16/2026 09:14:12 PAGE 2   

  54   1        norflash_cmd[7] = len&0xff;
  55   1        sys_write_vp(NOR_FLASH_ADDR,norflash_cmd,4);
  56   1        
  57   1        //2.等待操作完成
  58   1        while(1)
