 145          //解析处理数据
 146          unsigned char HMICommand()
 147          {
 148   1        unsigned char i;
 149   1        unsigned int tmp;
 150   1        unsigned char retVal;
 151   1      // 返回0 不发送数据 返回1发送数据
 152   1        retVal=0;
 153   1        switch (HmiSlvBuff.Item.Command)
 154   1        {
 155   2        case 3: //读取
 156   2          if (HmiSlvBuff.Item.DataValue==0 || HmiSlvBuff.Item.DataValue>115)
 157   2          {//异常或读取内容禁止处理   
 158   3            return 0;
 159   3          }
 160   2          HmiSlvSendBuff[0]=HmiSlvCmd.Addr;
 161   2          HmiSlvSendBuff[1]=3;
 162   2          HmiSlvSendBuff[2]=HmiSlvBuff.Item.DataValue*2;
 163   2          HmiSlvCmd.SendLength=HmiSlvSendBuff[2]+5;
 164   2          tmp=HmiSlvBuff.Item.RegisterAddr*2;
 165   2          T5L_ReadDgusBytes(HmiSlvBuff.Item.RegisterAddr,&HmiSlvSendBuff[3],HmiSlvSendBuff[2]);
 166   2          retVal=1;
 167   2          break;
 168   2        case 6: //写入
 169   2          T5L_WriteDgusBytes(HmiSlvBuff.Item.RegisterAddr,&HmiSlvBuff.Value[4],2);
 170   2          HmiSlvCmd.SendLength=8;
 171   2          for (i=0;i<6;i++)
 172   2          {
 173   3            HmiSlvSendBuff[i]=HmiSlvBuff.Value[i];
 174   3          }
