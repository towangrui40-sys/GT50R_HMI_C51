 175   2          retVal=1;
 176   2          break;
 177   2        case 16: //批量写入
 178   2          if(HmiSlvBuff.ItemX.DataValue==0 || HmiSlvBuff.ItemX.DataValue>125) return 0; //不能超过125个 word
 179   2          T5L_WriteDgusBytes(HmiSlvBuff.Item.RegisterAddr,HmiSlvBuff.ItemX.uint8,HmiSlvBuff.ItemX.ByteCount);   
 180   2          HmiSlvCmd.SendLength=8;
 181   2          for (i=0;i<6;i++)
 182   2          {
 183   3            HmiSlvSendBuff[i]=HmiSlvBuff.Value[i];
 184   3          }
