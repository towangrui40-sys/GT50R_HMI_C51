 192          //远程通讯响应子程序 返回2 解析命令
 193          unsigned char T5L_HMIslvSub()
 194          {
 195   1        unsigned char i;
 196   1        unsigned int tmp;
 197   1        unsigned char retVal;
 198   1        if (HmiSlvCmd.Status!=2) return 0;
 199   1        retVal=HMICommand();
 200   1        if (retVal==0)
 201   1        {
 202   2          HmiSlvCmd.Status=0;//无返回
 203   2          HmiSlvCmd.Step=0;
 204   2          return 0;
 205   2        }
 206   1        
 207   1        HmiSlvCmd.JsCrc.Data=0xffff;
 208   1        for (i=0;i<HmiSlvCmd.SendLength-2;i++){//计算包头块CRC
 209   2          tmp=CRC16_TABLE[(HmiSlvCmd.JsCrc.Data^HmiSlvSendBuff[i])&0x00ff];
 210   2          HmiSlvCmd.JsCrc.Data=(HmiSlvCmd.JsCrc.Data>>8)^tmp;
 211   2        }
 212   1        HmiSlvSendBuff[HmiSlvCmd.SendLength-2]=HmiSlvCmd.JsCrc.Value[1];
 213   1        HmiSlvSendBuff[HmiSlvCmd.SendLength-1]=HmiSlvCmd.JsCrc.Value[0];
 214   1      
 215   1        //发送数据
 216   1        HmiSlvCmd.Step=0;
 217   1        HmiSlvCmd.Length=1;
 218   1        HmiSlvCmd.Status=3;
 219   1        SBUF2_TX=HmiSlvSendBuff[0];
 220   1        return retVal;
