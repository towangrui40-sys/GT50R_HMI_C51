  70   2          case BTN_TYPE_CLICK:
  71   2            //检查是否有按钮按下
  72   2            if(obj->val !=0)
  73   2            {
  74   3              //按钮点击事件处理,传递给相应的界面 
  75   3              obj->func_callback(obj->addr,obj->val);     
