  77   3              obj->val = 0;
  78   3              sys_write_vp(obj->addr,(u8*)&obj->val,1); 
  79   3            }
  80   2            break;
  81   2          case BTN_TYPE_HOLD_RES:
  82   2            if(obj->val !=obj->val_temp)
  83   2            {
  84   3              obj->func_callback(obj->addr,obj->val);     
  85   3              obj->val_temp = obj->val;
  86   3              val=1;
  87   3              sys_write_vp(HOLD_ACTIVE_ADDR,(u8*)&val,1);
  88   3              val=0;
  89   3              sys_write_vp(HOLD_PASSIVE_ADDR,(u8*)&val,1);
  90   3            }       
  91   2            break;
  92   2          case BTN_TYPE_HOLD_TIME://click event,selected func
  93   2            if(obj->val !=0)
  94   2            {   
  95   3              if((obj->timer <10)&&(obj->val != obj->val_temp))
  96   3              {
  97   4                obj->func_callback(obj->addr,obj->val); 
  98   4              }
  99   3              if(obj->timer ==20)// 600ms hold event,popup shotkey select menu
 100   3              {
 101   4                obj->func_hold_callback(obj->addr,obj->val);
 102   4                //清除按键值
 103   4                obj->val = 0;
 104   4                sys_write_vp(obj->addr,(u8*)&obj->val,1);   
 105   4              }
 106   3              obj->timer++;
 107   3            }
 108   2            else
 109   2            {
 110   3              obj->timer = 0;
 111   3            }
 112   2            obj->val_temp = obj->val;
